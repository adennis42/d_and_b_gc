# Database (Vercel Postgres)
# Same database as main app
POSTGRES_URL=

# Vercel Blob Storage (for image uploads)
# Get token from Vercel dashboard > Storage > Blob > Settings
# Format: vercel_blob_rw_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
BLOB_READ_WRITE_TOKEN=

# NextAuth Configuration (NextAuth v5)
# Generate a secret with: openssl rand -base64 32
# Required for JWT token signing and encryption
AUTH_SECRET=
AUTH_URL=http://localhost:3001

# Google Analytics (Optional)
NEXT_PUBLIC_GA_ID=

# Cache Revalidation (for triggering main website cache updates)
# Same token as REVALIDATE_SECRET_TOKEN in main website
# Generate a secure random string: openssl rand -base64 32
REVALIDATE_SECRET_TOKEN=

# Main Website URL (for cache revalidation)
# URL of your main website (e.g., https://dbcontractorsny.com)
MAIN_SITE_URL=https://dbcontractorsny.com

