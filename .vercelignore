# Note: admin-dashboard is deployed as a separate Vercel project with Root Directory set to admin-dashboard
# We don't ignore it here because Vercel needs access to it when building from that directory
# The main site build won't include admin-dashboard files because it builds from root

# Ignore scripts directory (not needed for build)
scripts/

# Ignore documentation files
*.md
!README.md

# Ignore database schema files (not needed for build)
database/

# Ignore backup directories
public/images/gallery-backup/
public/images/gallery/

