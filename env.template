# Environment Variables Template for Contractor Website
# Copy this file to .env.local and fill in your actual values
# For Vercel deployment, add these variables in the Vercel dashboard under Settings > Environment Variables

# Email Configuration (Resend)
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=
EMAIL_FROM=
EMAIL_TO=

# Google Calendar Integration
# Get your Calendar ID from Google Calendar settings
# Get your API key from Google Cloud Console
GOOGLE_CALENDAR_ID=
GOOGLE_API_KEY=

# Analytics
# Google Analytics 4 Measurement ID (format: G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=

# Image Storage (Optional - if using Cloudinary)
# Get credentials from https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Site URL (for SEO - sitemap, structured data)
# Your production site URL (e.g., https://dbcontractorsny.com)
NEXT_PUBLIC_SITE_URL=

# Business Information (for Structured Data / LocalBusiness schema)
# Used for JSON-LD structured data to help search engines understand your business
NEXT_PUBLIC_BUSINESS_STREET=
NEXT_PUBLIC_BUSINESS_CITY=
NEXT_PUBLIC_BUSINESS_STATE=
NEXT_PUBLIC_BUSINESS_ZIP=
NEXT_PUBLIC_BUSINESS_COUNTRY=US
NEXT_PUBLIC_BUSINESS_PHONE=
NEXT_PUBLIC_BUSINESS_EMAIL=

# Business Hours (for Structured Data)
# Format: Comma-separated list, e.g., "Mo-Fr 08:00-17:00,Sa 09:00-13:00"
# Day abbreviations: Mo, Tu, We, Th, Fr, Sa, Su
NEXT_PUBLIC_BUSINESS_HOURS=Mo-Fr 08:00-17:00,Sa 09:00-13:00

# Service Areas (for Structured Data)
# Format: Comma-separated list of cities/regions served
# Example: "New York,Long Island,Westchester County"
NEXT_PUBLIC_SERVICE_AREAS=New York,Long Island,Westchester County

# Business Ratings (Optional - for AggregateRating in Structured Data)
# Only include if you have customer reviews/testimonials
NEXT_PUBLIC_RATING_VALUE=
NEXT_PUBLIC_REVIEW_COUNT=

# Business Images (Optional - for Structured Data)
NEXT_PUBLIC_BUSINESS_LOGO=/images/logo.png
NEXT_PUBLIC_BUSINESS_IMAGE=/images/og-image.jpg

