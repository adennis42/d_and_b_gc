# Environment Variables Template for Contractor Website
# Copy this file to .env.local and fill in your actual values
# For Vercel deployment, add these variables in the Vercel dashboard under Settings > Environment Variables

# Email Configuration (Resend)
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=
EMAIL_FROM=
EMAIL_TO=

# Google Calendar Integration
# Get your Calendar ID from Google Calendar settings
# Get your API key from Google Cloud Console
GOOGLE_CALENDAR_ID=
GOOGLE_API_KEY=

# Analytics
# Google Analytics 4 Measurement ID (format: G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=

# Image Storage (Optional - if using Cloudinary)
# Get credentials from https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

